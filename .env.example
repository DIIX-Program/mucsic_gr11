PORT=3000
JWT_SECRET=your_jwt_secret_here
DB_PATH=database.sqlite
# SQL Server Configuration
DB_SERVER=localhost
DB_NAME=musicdb
DB_USER= tự đi mò đi mày
DB_PASSWORD=lamgicomk để mày kiếm được cái này thì mày phải học SQL Server và cài đặt nó trên máy của mày, sau đó tạo một database có tên là musicdb và tạo một user có tên là sa với mật khẩu 123456, sau đó cấp quyền cho user sa truy cập vào database musicdb. Nếu mày không muốn sử dụng SQL Server thì mày có thể bỏ qua phần này và chỉ cần sử dụng SQLite với DB_PATH=database.sqlite là được.
NODE_ENV=development

# Vercel Deployment Note
# Vercel's filesystem is read-only.
# For Vercel, the app will automatically use /tmp for SQLite memory and uploads because process.env.VERCEL is set to "1" in that environment.
# Local development can just use database.sqlite.
